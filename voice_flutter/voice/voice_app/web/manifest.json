{
    "name": "Voice to Text Flutter",
    "description": "Flutter Voice to Text Extension",
    "version": "1.0.0",
    "manifest_version": 3,
    "permissions": [
        "sidePanel",
        "microphone"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "action": {
        "default_title": "Open Voice App"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
}